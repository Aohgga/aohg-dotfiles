#!/bin/sh

PREFIX_PERF="箚뱟-P"
PREFIX_BALA="箚푷-B"
PREFIX_SAVE="箚푺-S"

get_powerprofile() {
  profile=$(powerprofilesctl get)
  case "$profile" in
  performance)
    echo $PREFIX_PERF
    ;;
  balanced)
    echo $PREFIX_BALA
    ;;
  power-saver)
    echo $PREFIX_SAVE
    ;;
  esac

}

get_powerprofile
