#!/bin/bash

# INIT
printf "$$" >$HOME/.cache/blocks
sec=0

MODPATH=$HOME/.config/scripts/blocks/modules

update_speaker() {
  speaker=$($MODPATH/volume sink)
}

update_microphone() {
  microphone=$($MODPATH/volume source)
}

update_backlight() {
  backlight=$($MODPATH/backlight)
}

update_bluetooth() {
  bluetooth=$($MODPATH/bluetooth)
}

update_date() {
  date=$($MODPATH/date)
}

update_time() {
  time=$($MODPATH/time)
}

update_bat() {
  bat=$($MODPATH/battery)
}

update_powerprofile() {
  profile=$($MODPATH/powerprofile)
}

update_text() {
  text=$($MODPATH/text)
}

update_backlight
update_speaker
update_microphone
update_powerprofile
update_text

display() {
  local sep="]["
  local spa=" "
  local leftsep="["
  local rightsep="]"
  local logo=""
  local bar="$rightsep$rightsep$spa$spa$leftsep$text$sep$profile$spa$bluetooth$sep$speaker$spa$microphone$sep$backlight$spa$bat$sep$date$spa$time$rightsep$spa$logo$spa"
  xsetroot -name "$bar" >/dev/null 2>&1
}

trap "update_speaker;display" "RTMIN"
trap "update_backlight;display" "RTMIN+1"
trap "update_microphone;display" "RTMIN+2"
trap "update_powerprofile;display" "RTMIN+3"
trap "update_text;display" "RTMIN+4"

while true; do
  sleep 1 &
  wait && {
    [ $((sec % 5)) -eq 0 ] && update_speaker
    [ $((sec % 60)) -eq 0 ] && update_microphone
    [ $((sec % 5)) -eq 0 ] && update_bluetooth
    [ $((sec % 1)) -eq 0 ] && update_date
    [ $((sec % 1)) -eq 0 ] && update_time
    [ $((sec % 5)) -eq 0 ] && update_bat
    [ $((sec % 5)) -eq 0 ] && display
  }
done
